# Copy this file to .env and fill the secret values locally.
# Do not commit .env.

BOOK_RADAR_EMAIL_ENABLED=false
BOOK_RADAR_TELEGRAM_ENABLED=true

# Naver Mail SMTP defaults. Enable IMAP/SMTP in Naver Mail settings first.
SMTP_HOST=smtp.naver.com
SMTP_PORT=587

# Usually your full Naver email address.
SMTP_USERNAME=your_naver_id@naver.com

# Use your Naver password or application password if your account requires it.
SMTP_PASSWORD=replace_with_password_or_app_password

MAIL_FROM=your_naver_id@naver.com
MAIL_TO=qet882@naver.com

# Telegram notification settings. Create a bot with @BotFather, then send it any message
# and run scripts/get_telegram_chat_id.py to find the chat ID.
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_CHAT_ID=replace_with_telegram_chat_id
